# Optional development defaults. End users can set these in the app and keep them in localStorage.
# OpenAI-compatible text generation
OPENAI_API_KEY=your-openai-compatible-api-key
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4.1-mini

# Optional OpenAI-compatible image generation
OPENAI_IMAGE_BASE_URL=https://api.openai.com/v1
OPENAI_IMAGE_MODEL=your-openai-compatible-image-model
OPENAI_IMAGE_SIZE=1024x1024
OPENAI_IMAGE_RESPONSE_FORMAT=url

# Multi-turn composer context
VIBELIVE_MAX_CONVERSATION_MESSAGES=8
NEXT_PUBLIC_VIBELIVE_MAX_CONVERSATION_MESSAGES=8

# Legacy Ark-compatible config remains supported
ARK_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
ARK_API_KEY=your-volcengine-ark-api-key
ARK_MODEL=your-ark-endpoint-id-or-model-name
ARK_IMAGE_MODEL=doubao-seedream-5-0-260128
ARK_IMAGE_SIZE=2048x2048
ARK_IMAGE_RESPONSE_FORMAT=url
