{
  "name": "vibe-live",
  "version": "0.1.0",
  "private": true,
  "description": "A local-first ambient record generator and player.",
  "author": "VibeLive",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "build:desktop:web": "node scripts/build-desktop.mjs",
    "desktop:dev": "node scripts/dev-electron.mjs",
    "desktop:pack": "npm run build:desktop:web && electron-builder --mac dir",
    "desktop:dist": "npm run build:desktop:web && electron-builder --mac dmg zip",
    "start": "next start",
    "lint": "eslint .",
    "verify:music": "tsx scripts/verify-music-quality.ts",
    "deploy": "bash scripts/deploy.sh",
    "deploy:bootstrap": "bash scripts/deploy.sh --bootstrap",
    "postinstall": "node scripts/patch-strudel.mjs"
  },
  "dependencies": {
    "@strudel/core": "^1.2.6",
    "@strudel/mini": "^1.2.6",
    "@strudel/soundfonts": "^1.3.0",
    "@strudel/webaudio": "^1.3.0",
    "@types/three": "^0.184.1",
    "gsap": "^3.15.0",
    "next": "^16.2.7",
    "openai": "^6.42.0",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "three": "^0.184.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "22.15.3",
    "@types/react": "19.1.6",
    "@types/react-dom": "19.1.5",
    "electron": "^42.4.1",
    "electron-builder": "^26.15.3",
    "eslint": "9.28.0",
    "eslint-config-next": "^16.2.7",
    "tsx": "^4.22.4",
    "typescript": "5.8.3"
  },
  "build": {
    "appId": "app.vibelive.desktop",
    "productName": "VibeLive",
    "asar": true,
    "directories": {
      "output": "release"
    },
    "artifactName": "${productName}-${version}-${arch}.${ext}",
    "files": [
      "electron/**/*",
      "out/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "build/icon.png",
        "to": "icon.png"
      }
    ],
    "mac": {
      "category": "public.app-category.music",
      "icon": "build/icon.icns",
      "target": [
        "dmg",
        "zip"
      ]
    },
    "dmg": {
      "artifactName": "${productName}-${version}-${arch}.${ext}"
    }
  }
}
